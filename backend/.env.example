## MongoDB (Atlas)
# Paste your Atlas "Connect" string here (Database -> Connect -> Drivers).
# Example format:
# mongodb+srv://<username>:<password>@<cluster>.mongodb.net/psp?retryWrites=true&w=majority
MONGODB_URI=

# App
NODE_ENV=development
PORT=5000

# URLs (recommended for deployments)
# Used for OAuth callback URLs and links in emails (password reset, etc.)
BACKEND_URL=
FRONTEND_URL=
# Used for CORS (comma-separated). Example: https://your-frontend.com,*.vercel.app
FRONTEND_ORIGIN=

# Auth
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=

# Email (optional)
SMTP_HOST=
SMTP_PORT=587
EMAIL_USER=
EMAIL_APP_PASSWORD=
EMAIL_FROM_NAME=PSP Platform
EMAIL_FROM=

# Notification emails (optional)
NOTIFICATION_EMAILS_ENABLED=false

# OAuth (optional)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Support (optional) - used by the in-app chatbot responses
SUPPORT_EMAIL=
SUPPORT_PHONE=
SUPPORT_WHATSAPP=
SUPPORT_URL=
